{
  "name": "290-datenbanken-docs",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "diagrams:build": "node scripts/excalidraw/build-diagrams.mjs",
    "zips:build": "node scripts/assets/build-zips.mjs",
    "dev": "vitepress dev docs --host",
    "build": "npm run zips:build && vitepress build docs",
    "preview": "vitepress preview docs --host",
    "deploy": "gh-pages-clean && npm run build && gh-pages -d docs/.vitepress/dist --dotfiles"
  },
  "devDependencies": {
    "@excalidraw/utils": "^0.1.3-test32",
    "archiver": "^7.0.1",
    "gh-pages": "^6.3.0",
    "jsdom": "^29.0.2",
    "vitepress": "^1.6.4"
  }
}
